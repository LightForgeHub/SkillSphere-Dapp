// Prisma schema for the SkillSphere off-chain event indexer.
// Maps SessionCreated, SessionStarted, and SessionSettled contract events
// to typed Postgres tables, plus a cursor row to track the last indexed ledger.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Sync cursor ───────────────────────────────────────────────────────────────

/// Tracks the highest ledger sequence number fully processed.
/// There is always exactly one row (id = 1).
model SyncCursor {
  id              Int @id @default(1)
  lastLedgerSeq   Int @default(0)
  updatedAt       DateTime @updatedAt
}

// ── Session lifecycle events ───────────────────────────────────────────────────

/// Emitted when a new session is created (funds locked in escrow).
model SessionCreated {
  id            String   @id           // contract session_id (stringified u64)
  txHash        String
  ledgerSeq     Int
  timestamp     DateTime

  seekerAddress String
  expertAddress String
  /// Rate per second in stroops (1 XLM = 10_000_000 stroops)
  ratePerSecond BigInt
  /// Total escrow amount in stroops
  escrowAmount  BigInt

  createdAt     DateTime @default(now())
}

/// Emitted when the expert accepts and the stream starts.
model SessionStarted {
  id            String   @id           // contract session_id
  txHash        String
  ledgerSeq     Int
  timestamp     DateTime

  seekerAddress String
  expertAddress String
  ratePerSecond BigInt
  /// Ledger timestamp when streaming began
  startedAt     BigInt

  createdAt     DateTime @default(now())
}

/// Emitted when the session ends and funds are disbursed.
model SessionSettled {
  id            String   @id           // contract session_id
  txHash        String
  ledgerSeq     Int
  timestamp     DateTime

  expertAddress String
  /// Amount paid out to the expert in stroops
  expertPayout  BigInt
  /// Unused escrow refunded to seeker in stroops
  seekerRefund  BigInt
  /// Ledger timestamp when settlement happened
  settledAt     BigInt

  createdAt     DateTime @default(now())
}
